@{
    ViewData["Title"] = "Política de Seguridad y Privacidad";
}

<style>
    /* Configuración de estilo avanzada y original */
    .privacy-hero {
        background: linear-gradient(135deg, #198754 0%, #0d5a38 100%);
        color: white;
        padding: 4rem 2rem;
        border-radius: 20px 20px 0 0;
        text-align: center;
    }

    .privacy-body {
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 0 0 20px 20px;
        padding: 3rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .feature-point {
        border-radius: 15px;
        padding: 1.5rem;
        background: #f9fdfb;
        border-left: 5px solid #198754;
        margin-bottom: 2rem;
    }

    .icon-circle {
        width: 60px;
        height: 60px;
        background: #e8f5e9;
        color: #198754;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        margin-bottom: 1rem;
    }

    .institutional-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 2px dashed #dee2e6;
    }
</style>

<div class="container my-5">
    <div class="privacy-hero">
        <i class="bi bi-shield-check display-3 mb-3"></i>
        <h1 class="fw-bold">@ViewData["Title"]</h1>
        <p class="lead opacity-75">Garantizando la integridad del sistema EcoAbasto SV</p>
    </div>

    <div class="privacy-body">
        <div class="row">
            <div class="col-md-6">
                <div class="feature-point">
                    <div class="icon-circle">
                        <i class="bi bi-mortarboard"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Finalidad del Proyecto</h5>
                    <p class="text-muted small">
                        Este aplicativo web ha sido diseñado como un modelo de aprendizaje para la asignatura de <strong>Programación I</strong>, enfocado en el monitoreo de precios de productos esenciales.
                    </p>
                </div>
            </div>

            <div class="col-md-6">
                <div class="feature-point">
                    <div class="icon-circle">
                        <i class="bi bi-hdd-stack"></i>
                    </div>
                    <h5 class="fw-bold text-dark">Base de Datos Estructurada</h5>
                    <p class="text-muted small">
                        La gestión de información se realiza mediante la base de datos <strong>EcoAbastoDB</strong>, asegurando que cada registro de stock y precio cumpla con las reglas de negocio establecidas.
                    </p>
                </div>
            </div>
        </div>

        <div class="alert alert-success d-flex align-items-center rounded-4 border-0 shadow-sm p-4 mt-3">
            <i class="bi bi-check-circle-fill fs-2 me-3"></i>
            <div>
                <h6 class="fw-bold mb-1">Tecnología de Vanguardia</h6>
                <p class="mb-0 small">Implementado con ASP.NET Core y Entity Framework para un acceso a datos eficiente y seguro.</p>
            </div>
        </div>

        <div class="institutional-footer text-center">
            <p class="text-secondary fw-bold mb-1" style="letter-spacing: 1px;">SISTEMA DE MONITOREO 2026</p>
            <h6 class="text-dark mx-auto mt-3" style="max-width: 600px; line-height: 1.6;">
                Desarrollado por el equipo de estudiantes de la Regional Chalatenango, Facultad de Tecnología e Innovación
            </h6>
            
            <div class="mt-5">
                <a asp-action="Index" class="btn btn-success px-5 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-house-door me-2"></i>Ir al Inicio
                </a>
            </div>
        </div>
    </div>
</div>