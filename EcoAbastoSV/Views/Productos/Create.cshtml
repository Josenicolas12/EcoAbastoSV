@model EcoAbastoSv.Models.Producto

@{
    ViewData["Title"] = "Registrar Precio";
}

<div class="text-center mt-4">
    <h1 class="display-4" style="color: #2d5a27;"><i class="bi bi-plus-circle"></i> Nuevo Registro</h1>
    <p class="lead">Completa los datos para el monitoreo nacional.</p>
</div>

<div class="shadow-lg border-0 rounded-4" style="max-width: 550px; margin: 30px auto; padding: 35px; background-color: #ffffff;">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group mb-3">
            <label asp-for="Nombre" class="fw-bold">Producto</label>
            <input asp-for="Nombre" class="form-control" placeholder="Ej. Azúcar lb" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Precio" class="fw-bold">Precio ($)</label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Stock" class="fw-bold">Cantidad</label>
                <input asp-for="Stock" class="form-control" type="number" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Categoria" class="fw-bold">Categoría</label>
            <select asp-for="Categoria" class="form-control">
                <option value="">-- Seleccione Categoría --</option>
                <option value="Granos Básicos">Granos Básicos</option>
                <option value="Lácteos y Huevos">Lácteos y Huevos</option>
                <option value="Carnes">Carnes</option>
                <option value="Frutas y Verduras">Frutas y Verduras</option>
                <option value="Limpieza">Limpieza</option>
            </select>
            <span asp-validation-for="Categoria" class="text-danger"></span>
        </div>

        <div class="form-group mb-4">
            <label asp-for="Departamento" class="fw-bold">Departamento</label>
            <select asp-for="Departamento" class="form-control">
                <option value="">-- Seleccione Departamento --</option>
                <option value="Ahuachapán">Ahuachapán</option>
                <option value="Cabañas">Cabañas</option>
                <option value="Chalatenango">Chalatenango</option>
                <option value="Cuscatlán">Cuscatlán</option>
                <option value="La Libertad">La Libertad</option>
                <option value="La Paz">La Paz</option>
                <option value="La Unión">La Unión</option>
                <option value="Morazán">Morazán</option>
                <option value="San Miguel">San Miguel</option>
                <option value="San Salvador">San Salvador</option>
                <option value="San Vicente">San Vicente</option>
                <option value="Santa Ana">Santa Ana</option>
                <option value="Sonsonate">Sonsonate</option>
                <option value="Usulután">Usulután</option>
            </select>
            <span asp-validation-for="Departamento" class="text-danger"></span>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-success btn-lg w-100 shadow-sm mb-3">Guardar Registro</button>
            <a asp-action="Index" class="btn btn-link text-muted">Volver al Listado</a>
        </div>
    </form>
</div> 