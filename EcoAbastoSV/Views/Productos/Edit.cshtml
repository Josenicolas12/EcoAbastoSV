@model EcoAbastoSv.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="text-center mt-4">
    <h1 class="display-4" style="color: #0d6efd;"><i class="bi bi-pencil-square"></i> Editar Registro</h1>
    <p class="lead">Modifica la información del producto seleccionado.</p>
</div>

<div class="shadow-lg border-0 rounded-4" style="max-width: 550px; margin: 30px auto; padding: 35px; background-color: #f8fbff; border: 1px solid #cfe2ff !important;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3 text-start">
            <label asp-for="Nombre" class="fw-bold"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-group mb-3 text-start">
                <label asp-for="Precio" class="fw-bold"></label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-6 form-group mb-3 text-start">
                <label asp-for="Stock" class="fw-bold"></label>
                <input asp-for="Stock" class="form-control" type="number" />
            </div>
        </div>

        <div class="form-group mb-3 text-start">
            <label asp-for="Categoria" class="fw-bold"></label>
            <input asp-for="Categoria" class="form-control" />
            <span asp-validation-for="Categoria" class="text-danger"></span>
        </div>

        <div class="form-group mb-4 text-start">
            <label asp-for="Departamento" class="fw-bold"></label>
            <select asp-for="Departamento" class="form-control">
                <option value="Ahuachapán">Ahuachapán</option>
                <option value="Cabañas">Cabañas</option>
                <option value="Chalatenango">Chalatenango</option>
                <option value="Cuscatlán">Cuscatlán</option>
                <option value="La Libertad">La Libertad</option>
                <option value="La Paz">La Paz</option>
                <option value="La Unión">La Unión</option>
                <option value="Morazán">Morazán</option>
                <option value="San Miguel">San Miguel</option>
                <option value="San Salvador">San Salvador</option>
                <option value="San Vicente">San Vicente</option>
                <option value="Santa Ana">Santa Ana</option>
                <option value="Sonsonate">Sonsonate</option>
                <option value="Usulután">Usulután</option>
            </select>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm mb-2">Actualizar Datos</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>
