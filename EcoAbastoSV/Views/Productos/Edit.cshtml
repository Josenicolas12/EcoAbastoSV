@model EcoAbastoSv.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<div class="text-center">
    <h1 class="display-4" style="color: #2b6cb0;">📝 Editar Registro</h1>
    <p class="lead">Actualiza la información completa del inventario.</p>
</div>

<div style="max-width: 500px; margin: 20px auto; padding: 30px; border-radius: 15px; background-color: #f0f7ff; border: 2px solid #4299e1;">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Nombre" class="fw-bold"></label>
            <input asp-for="Nombre" class="form-control" />
            <span asp-validation-for="Nombre" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Precio" class="fw-bold"></label>
                <input asp-for="Precio" class="form-control" type="number" step="0.01" />
            </div>
            <div class="col-md-6 form-group mb-3">
                <label asp-for="Stock" class="fw-bold"></label>
                <input asp-for="Stock" class="form-control" type="number" />
            </div>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Categoria" class="fw-bold"></label>
            <input asp-for="Categoria" class="form-control" />
        </div>

        <div class="form-group mb-4">
            <label asp-for="Departamento" class="fw-bold"></label>
            <select asp-for="Departamento" class="form-control">
                <option value="San Salvador">San Salvador</option>
                <option value="Santa Ana">Santa Ana</option>
                <option value="San Miguel">San Miguel</option>
                <option value="La Libertad">La Libertad</option>
            </select>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary btn-lg w-100 mb-2">💾 Guardar Cambios</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    </form>
</div>