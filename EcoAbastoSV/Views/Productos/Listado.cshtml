@model IEnumerable<EcoAbastoSv.Models.Producto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Monitoreo de Canasta Básica</h2>
        <a asp-action="Create" class="btn btn-success">+ Registrar Nuevo Precio</a>
    </div>

    <table class="table table-hover shadow-sm border">
        <thead class="table-dark">
            <tr>
                <th>Producto</th>
                <th>Categoría</th>
                <th>Precio ($)</th>
                <th>Departamento</th>
                <th>Estado Stock</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">@item.Nombre</td>
                    <td>@item.Categoria</td>
                    @* Forzamos el símbolo de dólar y 2 decimales *@
                    <td>$@item.Precio?.ToString("N2")</td>
                    <td>@item.Departamento</td>
                    <td>
                        @if (item.Stock == 0)
                        {
                            <span class="badge bg-dark">Agotado</span>
                        }
                        else if (item.Stock < 10)
                        {
                            <span class="badge bg-danger">Escasez (@item.Stock)</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Disponible (@item.Stock)</span>
                        }
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('¿Está seguro de eliminar @item.Nombre?');">Borrar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>